# Godot 4+ engine cache
.godot/

# Exported builds (export_presets.cfg exports to Build/)
/Build/
/build/
/export/
*.exe
*.pck
*.zip

# .NET export sidecar (regenerated by every Windows export)
data_*_windows_x86_64/

# C# / .NET build artifacts
.mono/
bin/
obj/

# Local secrets (GD-Sync keys live here, merged over project.godot at boot)
override.cfg

# Tool-run scratch output (the run_*.bat files regenerate these)
*_log.txt
*_build.txt
*_run.txt

# OS / editor junk
.DS_Store
Thumbs.db
