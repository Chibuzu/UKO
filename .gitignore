# Godot 4+ engine cache
.godot/

# Exported builds (export_presets.cfg exports to Build/)
/Build/
/build/
/export/
*.exe
*.pck
*.zip

# .NET export sidecar (regenerated by every Windows export)
data_*_windows_x86_64/

# C# / .NET build artifacts
.mono/
bin/
obj/

# Local secrets (GD-Sync keys live here, merged over project.godot at boot)
override.cfg

# Tool-run scratch output (the run_*.bat / verify_all.bat files regenerate these)
*_log.txt
*_build.txt
*_run.txt
verify_*.txt

# OS / editor junk
.DS_Store
Thumbs.db
Tools/**/bin/
Tools/**/obj/
fast_harvest_build.txt
# Web export lands here (Tools/GameServer/web) and is served by run_server.bat.
# The build artifacts are big binaries -- never commit them.
Tools/GameServer/web/*
!Tools/GameServer/web/.gitkeep
